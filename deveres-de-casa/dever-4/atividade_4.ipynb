      "source": [
        "def recursion(n):\n",
        "  if n == 1:\n",
        "    return 2\n",
        "  return 2*recursion(n-1) + n**2"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "n = int(input(\"Digite o valor de n: \"))\n",
        "recursion(n)"
